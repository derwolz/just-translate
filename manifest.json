{
  "manifest_version": 3,
  "name": "Just Translate (X)",
  "version": "0.1.1",
  "description": "Auto-translates every X/Twitter post via Grok, without waiting for X's Show translation button.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "https://api.x.com/*",
    "https://api.twitter.com/*"
  ]
}
